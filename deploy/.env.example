# Copy to deploy/.env and edit before first run.

HELIOLYTICS_SIGNING_SECRET=change-me-to-a-long-random-string
HELIOLYTICS_WEB_PASSWORD=change-me-web-password
POSTGRES_PASSWORD=change-me-db-password

# Cloudflare Zero Trust tunnel token (production HTTPS — see deploy/deployment.md)
CLOUDFLARE_TUNNEL_TOKEN=

# Local-only bindings (127.0.0.1). Not exposed publicly when using cloudflared.
API_PORT=8080
WEB_PORT=3000
RATE_LIMIT_PER_MIN=120

# Admin reparse — disabled by default (POST /api/v1/reparse)
REPARSE_ENABLED=false
REPARSE_SECRET=

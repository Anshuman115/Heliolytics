# TLS reverse proxy — terminates HTTPS and forwards to internal services.
# Uses Caddy internal CA (self-signed). Trust the cert in your browser for LAN use,
# or replace with your own domain + Let's Encrypt for public deploy.

{
  auto_https disable_redirects
}

:443 {
  tls internal

  handle /health {
    reverse_proxy api:8080
  }

  handle /api/* {
    reverse_proxy api:8080
  }

  handle {
    reverse_proxy web:3000
  }
}
